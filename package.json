{
  "name": "@agentic/bp",
  "version": "1.0.0",
  "description": "CLI utility that scaffolds and verifies governance structures for agentic AI tools",
  "type": "module",
  "main": "./dist/cli/index.js",
  "exports": {
    ".": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "types": "./dist/cli/index.d.ts",
  "sideEffects": false,
  "bin": {
    "bp": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run ci",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:e2e": "vitest run tests/e2e/",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude 'tests/e2e/**'",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "lint:no-sync-fs": "! grep -n 'fs\\.readFileSync\\|fs\\.readdirSync\\|fs\\.accessSync\\|fs\\.statSync\\|fs\\.existsSync' src/detector/index.ts src/validator/index.ts src/validator/structural.ts src/templater/index.ts src/templater/writer.ts src/templater/engine.ts 2>/dev/null && echo 'lint:no-sync-fs PASS'",
    "lint:no-interior-exit": "! grep -rn 'process\\.exit(' src/ --include='*.ts' | grep -v 'src/cli/index.ts:' && echo 'lint:no-interior-exit PASS'",
    "lint:no-require": "! grep -rn 'require(' src/ --include='*.ts' | grep -v '//' | grep -v 'packs.ts' | grep -v 'lsp/server.ts' && echo 'lint:no-require PASS'",
    "lint:custom": "npm run lint:no-sync-fs && npm run lint:no-interior-exit && npm run lint:no-require",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint && npm run lint:custom && npm run test:coverage",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xkhdr/open-blueprint.git"
  },
  "keywords": [
    "cli",
    "blueprint",
    "claude",
    "cursor",
    "agentic",
    "scaffolding"
  ],
  "author": "Mohamed Khedr",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "bugs": {
    "url": "https://github.com/0xkhdr/open-blueprint/issues"
  },
  "homepage": "https://github.com/0xkhdr/open-blueprint#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@types/diff": "^5.2.3",
    "@types/handlebars": "^4.0.40",
    "@types/node": "^25.9.1",
    "@types/ora": "^3.1.0",
    "@types/picomatch": "^4.0.3",
    "@types/pino": "^7.0.4",
    "@vitest/coverage-v8": "^4.1.7",
    "fast-check": "^4.8.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cliui": "^9.0.1",
    "commander": "^14.0.3",
    "diff": "^9.0.0",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "ink": "^7.0.4",
    "ora": "^9.4.0",
    "picomatch": "^4.0.4",
    "pino": "^10.3.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  }
}
