{
  "backend": "cursor",
  "version": "2026.1",
  "supported_features": {
    "anchors": true,
    "rules": true,
    "skills": true,
    "agents": true,
    "hooks": false
  },
  "file_patterns": {
    "anchor": ["context.md", ".cursor/context.md"],
    "rules": ".cursor/rules/*.md",
    "skills": ".cursor/skills/*.md",
    "agents": ".cursor/agents/*.md",
    "hooks": ""
  },
  "max_file_sizes": {
    "anchor": 5000,
    "rules": 10000,
    "skills": 15000,
    "agents": 8000
  },
  "frontmatter_schema": {
    "rules": {
      "required": ["scope", "severity"],
      "optional": ["action", "rationale", "tags"],
      "severity_values": ["hard", "soft", "info"]
    },
    "skills": {
      "required": ["name", "description"],
      "optional": ["tools_required", "when_to_use"]
    },
    "agents": {
      "required": ["name"],
      "optional": ["role", "reasoning_style", "allowed_tools"]
    }
  }
}
