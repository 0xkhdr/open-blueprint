{
  "name": "open-blueprint-vscode",
  "displayName": "Open Blueprint VS Code Extension",
  "description": "VS Code support for open-blueprint, validating spatial anchors, rules, and skills.",
  "version": "1.0.0",
  "publisher": "agentic",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "workspaceContains:CLAUDE.md",
    "workspaceContains:.bp.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "blueprint.init",
        "title": "Blueprint: Initialize",
        "category": "Blueprint"
      },
      {
        "command": "blueprint.verify",
        "title": "Blueprint: Verify Current File",
        "category": "Blueprint"
      },
      {
        "command": "blueprint.syncDrift",
        "title": "Blueprint: Sync Drift",
        "category": "Blueprint"
      },
      {
        "command": "blueprint.openDocs",
        "title": "Blueprint: Open Documentation",
        "category": "Blueprint"
      }
    ],
    "languages": [
      {
        "id": "blueprint-rule",
        "filenames": [],
        "filenamePatterns": [
          ".claude/rules/*.md"
        ],
        "configuration": "./language-config.json"
      },
      {
        "id": "blueprint-skill",
        "filenames": [],
        "filenamePatterns": [
          ".claude/skills/*.md"
        ],
        "configuration": "./language-config.json"
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/blueprint.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
